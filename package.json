{
  "name": "chrome-ai-assistant",
  "version": "1.0.0",
  "description": "Chrome extension that enables AI-powered page interaction using WebMCP protocol",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "compile": "wxt compile",
    "postinstall": "wxt prepare",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest --run"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "element-plus": "^2.8.0",
    "marked": "^12.0.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0",
    "web-ext": "^10.0.0",
    "wxt": "^0.19.0"
  }
}
